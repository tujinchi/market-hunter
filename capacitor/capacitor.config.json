{
  "appId": "com.markethunter.app",
  "appName": "市场猎手",
  "webDir": "../public",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://a65c72634f914fa09ee79d3ad34e5885.app.codebuddy.work",
    "cleartext": false
  },
  "backgroundColor": "#080c14",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#080c14",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "spinnerColor": "#3b82f6"
